{
    "swagger": "2.0",
    "info": {
        "description": "Simulação do sistema PIX com arquitetura hexagonal + DDD + Kafka",
        "title": "PIX API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8000",
    "basePath": "/",
    "paths": {
        "/api/v1/accounts": {
            "post": {
                "description": "Creates a new bank account. The initial balance is zero; use the deposit endpoint to add funds.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Accounts"
                ],
                "summary": "Create account",
                "parameters": [
                    {
                        "description": "Account payload",
                        "name": "account",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/httpadapter.CreateAccountRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.AccountResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/accounts/{id}": {
            "get": {
                "description": "Returns account details by ID",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Accounts"
                ],
                "summary": "Get account",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Account UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.AccountResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/accounts/{id}/balance": {
            "get": {
                "description": "Returns current balance in cents",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Accounts"
                ],
                "summary": "Get account balance",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Account UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.BalanceResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/accounts/{id}/deposit": {
            "post": {
                "description": "Adds funds to an account (simulation — no real banking involved)",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Accounts"
                ],
                "summary": "Deposit to account",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Account UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Deposit payload",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/httpadapter.DepositRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.AccountResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/accounts/{id}/pix/keys": {
            "get": {
                "description": "Returns all active PIX keys linked to an account",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "PIX Keys"
                ],
                "summary": "List PIX keys of an account",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Account UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/httpadapter.PixKeyResponse"
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/accounts/{id}/pix/payments": {
            "get": {
                "description": "Returns all PIX transactions where the account was the payer",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Payments"
                ],
                "summary": "List payments made by an account",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Account UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/httpadapter.TransactionResponse"
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/pix/keys": {
            "post": {
                "description": "Registers a new PIX key (CPF, CNPJ, PHONE, EMAIL or EVP) for an account",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "PIX Keys"
                ],
                "summary": "Register a PIX key",
                "parameters": [
                    {
                        "description": "PIX key payload",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/httpadapter.RegisterPixKeyRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.PixKeyResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    },
                    "422": {
                        "description": "Unprocessable Entity",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/pix/keys/{key}": {
            "get": {
                "description": "Returns the account associated with a PIX key value",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "PIX Keys"
                ],
                "summary": "Get PIX key info",
                "parameters": [
                    {
                        "type": "string",
                        "description": "PIX key value",
                        "name": "key",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.PixKeyResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    }
                }
            },
            "delete": {
                "description": "Removes a PIX key. Requires account_id query param for ownership verification.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "PIX Keys"
                ],
                "summary": "Delete a PIX key",
                "parameters": [
                    {
                        "type": "string",
                        "description": "PIX key value",
                        "name": "key",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Owner account UUID",
                        "name": "account_id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No Content"
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/pix/payments": {
            "post": {
                "description": "Creates a new PIX payment. The transfer is processed asynchronously via Kafka. Returns 202 Accepted with the transaction in PENDING status.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Payments"
                ],
                "summary": "Initiate a PIX payment",
                "parameters": [
                    {
                        "description": "Payment payload",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/httpadapter.InitiatePaymentRequest"
                        }
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Accepted",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.TransactionResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    },
                    "422": {
                        "description": "Unprocessable Entity",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/pix/payments/{id}": {
            "get": {
                "description": "Returns current status and details of a PIX transaction",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Payments"
                ],
                "summary": "Get transaction by ID",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Transaction UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.TransactionResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/httpadapter.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "description": "Returns API and database status",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Health"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "httpadapter.AccountResponse": {
            "type": "object",
            "properties": {
                "balance_cents": {
                    "type": "integer"
                },
                "cpf": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "owner_name": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                }
            }
        },
        "httpadapter.BalanceResponse": {
            "type": "object",
            "properties": {
                "account_id": {
                    "type": "string"
                },
                "balance": {
                    "type": "string"
                },
                "balance_cents": {
                    "type": "integer"
                }
            }
        },
        "httpadapter.CreateAccountRequest": {
            "type": "object",
            "required": [
                "cpf",
                "owner_name"
            ],
            "properties": {
                "cpf": {
                    "type": "string"
                },
                "owner_name": {
                    "type": "string",
                    "maxLength": 255,
                    "minLength": 2
                }
            }
        },
        "httpadapter.DepositRequest": {
            "type": "object",
            "required": [
                "amount_cents"
            ],
            "properties": {
                "amount_cents": {
                    "type": "integer",
                    "minimum": 1
                }
            }
        },
        "httpadapter.ErrorResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string"
                }
            }
        },
        "httpadapter.InitiatePaymentRequest": {
            "type": "object",
            "required": [
                "amount_cents",
                "payer_account_id",
                "receiver_key"
            ],
            "properties": {
                "amount_cents": {
                    "type": "integer",
                    "minimum": 1
                },
                "description": {
                    "type": "string",
                    "maxLength": 140
                },
                "payer_account_id": {
                    "type": "string"
                },
                "receiver_key": {
                    "type": "string"
                }
            }
        },
        "httpadapter.PixKeyResponse": {
            "type": "object",
            "properties": {
                "account_id": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "key_type": {
                    "type": "string"
                },
                "key_value": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                }
            }
        },
        "httpadapter.RegisterPixKeyRequest": {
            "type": "object",
            "required": [
                "account_id",
                "key_type",
                "key_value"
            ],
            "properties": {
                "account_id": {
                    "type": "string"
                },
                "key_type": {
                    "type": "string"
                },
                "key_value": {
                    "type": "string"
                }
            }
        },
        "httpadapter.TransactionResponse": {
            "type": "object",
            "properties": {
                "amount_cents": {
                    "type": "integer"
                },
                "completed_at": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "failure_reason": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "initiated_at": {
                    "type": "string"
                },
                "payer_account_id": {
                    "type": "string"
                },
                "receiver_account_id": {
                    "type": "string"
                },
                "receiver_key": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                }
            }
        }
    }
}