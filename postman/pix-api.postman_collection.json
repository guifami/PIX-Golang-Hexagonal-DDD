              "listen": "test",
              "script": {
                "exec": [
                  "// 401 somente quando API_KEYS não está vazio no servidor",
                  "pm.test('401 ou 200 conforme configuração de API_KEYS', () => {",
                  "  pm.expect([200, 401]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
