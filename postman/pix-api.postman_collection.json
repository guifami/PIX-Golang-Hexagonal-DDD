          "name": "Sem Header X-API-Key (401 se auth habilitada)",
          "description": "Testa ausência total do header. Retorna 401 quando API_KEYS está configurado.",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/accounts/{{payer_account_id}}",
              "host": ["{{base_url}}"],
