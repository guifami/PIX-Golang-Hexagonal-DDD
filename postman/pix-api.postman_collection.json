        {
          "name": "API Key Inválida (401)",
          "description": "Só retorna 401 se API_KEYS estiver configurado no servidor. Com API_KEYS vazio, retorna 200.",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "chave-invalida-que-nao-existe" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/accounts/{{payer_account_id}}",
              "host": ["{{base_url}}"],
              "path": ["api","v1","accounts","{{payer_account_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Retorna 401 somente se API_KEYS estiver configurado no servidor",
                  "pm.test('Status 401 ou 200 (depende de API_KEYS estar configurado)', () => {",
                  "  pm.expect([200, 401]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 401) {",
                  "  pm.test('Error message about API key', () => {",
